generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  REGISTRATION
  AUTHORIZATION
  ADMIN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  password           String
  name               String?
  role               Role     @default(REGISTRATION)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  hashedRefreshToken String?

  payments Payment[]
}

model Payment {
  id          Int           @id @default(autoincrement())
  cnpj        String
  companyName String
  amount      Float
  description String
  status      PaymentStatus @default(PENDING)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}